# Datasource mode: mock (default) or supabase
CONTENT_DATA_SOURCE=mock

# Supabase (needed when CONTENT_DATA_SOURCE=supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONTENT_TABLE=content_items
SUPABASE_DB_URL=

# Optional stub input for stage-2 foundation.
# JSON array met SupabaseContentRow records.
SUPABASE_CONTENT_ROWS_JSON=

# Instagram test-ingest (proof-of-ingestion, beperkte scope)
META_SYSTEM_USER_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_GRAPH_VERSION=v23.0
# Optioneel overschrijven (anders afgeleid van version)
INSTAGRAM_GRAPH_API_BASE_URL=
# Beperkte ingestie voor gecontroleerde test-run (max 20)
INSTAGRAM_TEST_INGEST_LIMIT=5
# Optioneel: komma-gescheiden source ids voor een nog kleinere selectie
INSTAGRAM_TEST_SOURCE_IDS=
# Optioneel: limiet voor herhaalbare full sync; leeg = alle pagina's ophalen
INSTAGRAM_SYNC_LIMIT=
# Optioneel: page size voor full sync
INSTAGRAM_SYNC_PAGE_SIZE=50

# Mailchimp nieuwsbrief
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=
